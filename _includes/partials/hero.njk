{# ─────────────────────────────────────────
   hero.njk
   Unified page hero. Driven entirely by `hero` frontmatter.
   Renders nothing if no hero data is present.

   See _foundations/classes/hero.md for the MetaMenu schema.
   See _styles/partials/_hero.scss for styles.
───────────────────────────────────────── #}

{% if hero %}

{# Logo key → path map. Add entries here as new logos are introduced.
   Until logo reorganization (step 6), "logo" resolves to the existing file
   shared with nav and footer. #}
{%- set logoMap = {
  logo:   "/assets/img/logo.png",
  rooted: "/assets/img/logo.png",
  sage:   "/assets/img/logos/sage.png"
} -%}

{# Themes considered "dark" — retained for any future per-theme logic,
   but not used for button translation. Frontmatter is authoritative. #}
{%- set darkThemes = ["retreat", "zine", "workshop-ember", "workshop-botanica", "workshop-lunar", "workshop-ceremony", "workshop-root"] -%}
{%- set isDark = theme in darkThemes -%}

{# Title parsing: "The Rooted | Wisdom" → main + italic parts.
   Always split; a title without a pipe yields a 1-element array. #}
{%- set heroTitle = hero.title or "" -%}
{%- set titleParts = heroTitle | split("|") -%}
{%- set titleMain = titleParts[0] | trim -%}
{%- set titleItalic = "" -%}
{%- if titleParts | length > 1 -%}
  {%- set titleItalic = titleParts[1] | trim -%}
{%- endif -%}

{%- set heroSize = hero.size or "full" -%}

<section class="hero" data-size="{{ heroSize }}">

  {# ── Glyphs (each corner independently optional) ── #}
  {%- if hero.glyphs -%}
    {%- set gTL = hero.glyphs["top-left"] -%}
    {%- set gTR = hero.glyphs["top-right"] -%}
    {%- set gBL = hero.glyphs["bottom-left"] -%}
    {%- set gBR = hero.glyphs["bottom-right"] -%}
    {%- if gTL %}<div class="hero-glyph hero-glyph--tl" aria-hidden="true">{% glyph gTL %}</div>{% endif -%}
    {%- if gTR %}<div class="hero-glyph hero-glyph--tr" aria-hidden="true">{% glyph gTR %}</div>{% endif -%}
    {%- if gBL %}<div class="hero-glyph hero-glyph--bl" aria-hidden="true">{% glyph gBL %}</div>{% endif -%}
    {%- if gBR %}<div class="hero-glyph hero-glyph--br" aria-hidden="true">{% glyph gBR %}</div>{% endif -%}
  {%- endif -%}

  <div class="hero-inner">

    {# ── Logo ── #}
    {%- if hero.logo and logoMap[hero.logo] -%}
      <img class="hero-logo{% if hero.logo == 'sage' %} hero-logo--zine{% endif %}"
           src="{{ logoMap[hero.logo] }}"
           alt=""
           aria-hidden="true" />
    {%- endif -%}

    {# ── Eyebrow (required by convention but render defensively) ── #}
    {%- if hero.eyebrow -%}
      <p class="hero-eyebrow">{{ hero.eyebrow }}</p>
    {%- endif -%}

    {# ── Kicker (dashed announcement line) ── #}
    {%- if hero.kicker -%}
      <p class="hero-kicker">{{ hero.kicker }}</p>
    {%- endif -%}

    {# ── Title ── #}
    {%- if heroTitle -%}
      <h1 class="hero-title">
        {{ titleMain }}{% if titleItalic %} <em>{{ titleItalic }}</em>{% endif %}
      </h1>
    {%- endif -%}

    {# ── Divider ornament ── #}
    {%- if hero.divider -%}
      <div class="hero-divider" aria-hidden="true">{% glyph hero.divider %}</div>
    {%- endif -%}

    {# ── Date range (retreat only, driven by Date object) ── #}
    {%- if hero.date and hero.date["start-date"] -%}
      <p class="hero-date">{{ hero.date["start-date"] | dateRange(hero.date["end-date"]) }}</p>
    {%- endif -%}

    {# ── Subtitle (italic serif line) ── #}
    {%- if hero.subtitle -%}
      <p class="hero-subtitle">{{ hero.subtitle }}</p>
    {%- endif -%}

    {# ── Description ── #}
    {%- if hero.description -%}
      <p class="hero-desc">{{ hero.description }}</p>
    {%- endif -%}

    {# ── CTA buttons ──
       btn-class passes through directly to your button system.
       Valid values: primary, ghost, subtle, blue, blue-ghost, dark-primary, dark-ghost.
       Whatever you put here gets prefixed with `btn--`. No translation. #}
    {%- if hero.cta and hero.cta | length -%}
      <div class="hero-cta">
      {%- for item in hero.cta -%}
        {%- set btn = item.btn -%}
        {%- if btn and btn["btn-label"] -%}
          {%- set rawClass = btn["btn-class"] or "primary" -%}
        <a href="{{ btn['btn-link'] or '#' }}" class="btn btn--{{ rawClass }}">{{ btn["btn-label"] }}</a>
        {%- endif -%}
      {%- endfor -%}
      </div>
    {%- endif -%}

  </div>

  {# ── Scroll indicator (tall heroes only) ── #}
  {%- if heroSize == "full" -%}
    <div class="hero-scroll" aria-hidden="true">Scroll</div>
  {%- endif -%}

</section>

{% endif %}
